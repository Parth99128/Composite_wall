{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["composite-wall-backend-v3/**"]
  },
  "deploy": {
    "startCommand": "cd composite-wall-backend-v3 && npm install && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
